# Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# .env.local is NOT committed to git (see .gitignore)

# WhatsApp Business Phone Number
# Used for consultation booking redirect
NEXT_PUBLIC_WHATSAPP_NUMBER=918098118198

# Email Configuration
# If adding email functionality in the future
NEXT_PUBLIC_CONTACT_EMAIL=adminskyfly2026@gmail.com

# Analytics (if using Vercel Analytics)
# Available in Vercel dashboard
NEXT_PUBLIC_ANALYTICS_ID=

# API Endpoints (if building backend)
# Example: https://api.example.com
NEXT_PUBLIC_API_URL=http://localhost:3000

# Google Maps API Key (if custom map needed)
# Get from https://cloud.google.com/maps-platform
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Contact Form Backend (if adding backend)
# Example: https://api.example.com/submit-contact
NEXT_PUBLIC_FORM_API_ENDPOINT=
